{
  "name": "paynest",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "typecheck": "tsc --noEmit",
    "db:link": "set -a; [ -f supabase/.env ] && . ./supabase/.env; set +a; : \"${SUPABASE_PROJECT_REF:?Set SUPABASE_PROJECT_REF in supabase/.env}\"; npx supabase link --project-ref \"$SUPABASE_PROJECT_REF\"",
    "db:push": "set -a; [ -f supabase/.env ] && . ./supabase/.env; set +a; npx supabase db push",
    "db:migrate": "npm run db:link && npm run db:push"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~53.0.22",
    "expo-asset": "~11.1.7",
    "expo-notifications": "~0.31.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.20.0",
    "simple-icons": "^16.24.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
