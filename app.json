{
  "expo": {
    "name": "Paynest",
    "slug": "paynest",
    "version": "0.0.0",
    "orientation": "portrait",
    "icon": "./assets/paynest.png",
    "backgroundColor": "#F7F8FA",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-status-bar",
        {
          "style": "dark",
          "hidden": false
        }
      ],
      [
        "expo-navigation-bar",
        {
          "style": "dark",
          "hidden": false,
          "enforceContrast": false
        }
      ],
      [
        "expo-build-properties",
        {
          "buildReactNativeFromSource": false
        }
      ]
    ],
    "ios": {
      "icon": "./assets/paynest.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.tfourj.paynest"
    },
    "android": {
      "backgroundColor": "#F7F8FA",
      "icon": "./assets/paynest-android-foreground.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/paynest-android-foreground.png",
        "backgroundImage": "./assets/paynest-android-background.png"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.tfourj.paynest"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/paynest.png"
    }
  }
}
