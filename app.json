{
  "expo": {
    "name": "Paynest",
    "slug": "paynest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/paynest.png",
    "backgroundColor": "#F7F8FA",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#F7F8FA",
      "translucent": false
    },
    "androidNavigationBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#F7F8FA",
      "enforceContrast": false
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "buildReactNativeFromSource": false
        }
      ]
    ],
    "ios": {
      "icon": "./assets/paynest.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.tfourj.paynest"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "backgroundColor": "#F7F8FA",
      "icon": "./assets/paynest.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/paynest.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.tfourj.paynest"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/paynest.png"
    }
  }
}
